<?xml version="1.0" encoding="UTF-8"?>
<thing:thing-descriptions bindingId="catlink"
	xmlns:thing="https://openhab.org/schemas/thing-description/v1.0.0"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="https://openhab.org/schemas/thing-description/v1.0.0 https://openhab.org/schemas/thing-description-1.0.0.xsd">

	<!-- ============================ Account (bridge) ============================ -->
	<bridge-type id="account">
		<label>CatLink Account</label>
		<description>A CatLink cloud account. Use a dedicated shared (sub-)account, since the cloud allows only one active
			session per account.</description>
		<config-description>
			<parameter name="email" type="text" required="false">
				<label>Email</label>
				<description>The account's email address. Use this OR the phone number, matching how you log into the CatLink app.</description>
			</parameter>
			<parameter name="phone" type="text" required="false">
				<label>Phone Number</label>
				<description>The account's phone number (without the international prefix). Leave empty if logging in with email.</description>
			</parameter>
			<parameter name="phoneIac" type="text" required="false">
				<label>International Calling Code</label>
				<description>Country dial prefix for phone login, e.g. 86, 36, 1.</description>
				<default>86</default>
			</parameter>
			<parameter name="password" type="text" required="true">
				<label>Password</label>
				<context>password</context>
				<description>The account password (entered in plain text; encrypted before transmission).</description>
			</parameter>
			<parameter name="region" type="text" required="true">
				<label>Region</label>
				<description>Which CatLink server to use.</description>
				<options>
					<option value="global">Global</option>
					<option value="usa">USA</option>
					<option value="singapore">Singapore</option>
					<option value="china">China</option>
				</options>
				<default>global</default>
				<limitToOptions>true</limitToOptions>
			</parameter>
			<parameter name="language" type="text">
				<label>Language</label>
				<description>Language header sent to the API, e.g. en_US.</description>
				<default>en_US</default>
			</parameter>
			<parameter name="refreshInterval" type="integer" unit="s" min="15">
				<label>Refresh Interval</label>
				<description>How often (seconds) to poll device state.</description>
				<default>60</default>
			</parameter>
		</config-description>
	</bridge-type>

	<!-- ============================ Scooper (generic) ============================ -->
	<thing-type id="scooper">
		<supported-bridge-type-refs>
			<bridge-type-ref id="account"/>
		</supported-bridge-type-refs>
		<label>CatLink Scooper</label>
		<description>A CatLink self-cleaning litter box (generic Scooper).</description>
		<channels>
			<channel id="state" typeId="state"/>
			<channel id="mode" typeId="mode-scooper"/>
			<channel id="action" typeId="action-litterbox"/>
			<channel id="litter-weight" typeId="litter-weight"/>
			<channel id="litter-remaining-days" typeId="litter-remaining-days"/>
			<channel id="temperature" typeId="temperature"/>
			<channel id="humidity" typeId="humidity"/>
			<channel id="total-clean-time" typeId="total-clean-time"/>
			<channel id="manual-clean-time" typeId="manual-clean-time"/>
			<channel id="deodorant-countdown" typeId="deodorant-countdown"/>
			<channel id="key-lock" typeId="key-lock"/>
			<channel id="online" typeId="online"/>
			<channel id="last-log" typeId="last-log"/>
			<channel id="alarm" typeId="alarm"/>
			<channel id="error" typeId="error"/>
		</channels>
		<representation-property>deviceId</representation-property>
		<config-description-ref uri="thing-type:catlink:device"/>
	</thing-type>

