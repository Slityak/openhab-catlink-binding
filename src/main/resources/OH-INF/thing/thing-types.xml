	<!-- ============================ Cat (per-cat health) ============================ -->
	<thing-type id="cat">
		<supported-bridge-type-refs>
			<bridge-type-ref id="account"/>
		</supported-bridge-type-refs>
		<label>CatLink Cat</label>
		<description>A cat's health profile and daily statistics from the CatLink cloud.</description>
		<channels>
			<channel id="status" typeId="ro-string">
				<label>Status</label>
			</channel>
			<channel id="weight" typeId="weight">
				<label>Weight</label>
			</channel>
			<channel id="age-years" typeId="ro-number">
				<label>Age (Years)</label>
			</channel>
			<channel id="age-months" typeId="ro-number">
				<label>Age (Months)</label>
			</channel>
			<channel id="gender" typeId="ro-string">
				<label>Gender</label>
			</channel>
			<channel id="breed" typeId="ro-string">
				<label>Breed</label>
			</channel>
			<channel id="toilet-times" typeId="ro-number">
				<label>Toilet Times</label>
			</channel>
			<channel id="toilet-weight-avg" typeId="ro-number">
				<label>Measured Weight (kg)</label>
				<description>The cat's average weight (kg) measured by the litter box during toilet visits. Equals the registered
					weight until visit data is collected.</description>
			</channel>
			<channel id="pee-times" typeId="ro-number">
				<label>Pee Times</label>
			</channel>
			<channel id="poo-times" typeId="ro-number">
				<label>Poo Times</label>
			</channel>
			<channel id="drink-times" typeId="ro-number">
				<label>Drink Times</label>
			</channel>
			<channel id="diet-times" typeId="ro-number">
				<label>Diet Times</label>
			</channel>
			<channel id="diet-intakes" typeId="ro-number">
				<label>Diet Intakes</label>
			</channel>
			<channel id="sport-duration" typeId="ro-number">
				<label>Active Duration</label>
			</channel>
		</channels>
		<representation-property>petId</representation-property>
		<config-description>
			<parameter name="petId" type="text" required="true">
				<label>Pet ID</label>
				<description>The CatLink pet id (filled in automatically by discovery).</description>
			</parameter>
		</config-description>
	</thing-type>

	<!-- ============================ Channel types ============================ -->
	<channel-type id="state">
		<item-type>String</item-type>
		<label>Work Status</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="mode-scooper">
		<item-type>String</item-type>
		<label>Mode</label>
		<description>Cleaning mode.</description>
		<state>
			<options>
				<option value="auto">Auto</option>
				<option value="manual">Manual</option>
				<option value="time">Time</option>
				<option value="empty">Empty</option>
			</options>
		</state>
	</channel-type>

	<channel-type id="mode-litterbox">
		<item-type>String</item-type>
		<label>Mode</label>
		<description>Cleaning mode.</description>
		<state>
			<options>
				<option value="auto">Auto</option>
				<option value="manual">Manual</option>
				<option value="time">Time</option>
			</options>
		</state>
	</channel-type>

	<channel-type id="mode-c08">
		<item-type>String</item-type>
		<label>Mode</label>
		<description>Cleaning mode.</description>
		<state>
			<options>
				<option value="auto">Auto</option>
				<option value="manual">Manual</option>
				<option value="scheduled">Scheduled</option>
			</options>
		</state>
	</channel-type>

	<channel-type id="mode-purepro">
		<item-type>String</item-type>
		<label>Mode</label>
		<description>Fountain run mode.</description>
		<state>
			<options>
				<option value="flowing">Flowing</option>
				<option value="eco">Eco</option>
				<option value="smart">Smart</option>
			</options>
		</state>
	</channel-type>

	<channel-type id="action-litterbox">
		<item-type>String</item-type>
		<label>Action</label>
		<description>Start or pause cleaning.</description>
		<command>
			<options>
				<option value="start">Start</option>
				<option value="pause">Pause</option>
			</options>
		</command>
	</channel-type>

	<channel-type id="action-c08">
		<item-type>String</item-type>
		<label>Action</label>
		<description>Clean / pave control.</description>
		<command>
			<options>
				<option value="clean-start">Clean: Start</option>
				<option value="clean-pause">Clean: Pause</option>
				<option value="clean-cancel">Clean: Cancel</option>
				<option value="pave-start">Pave: Start</option>
				<option value="pave-pause">Pave: Pause</option>
			</options>
		</command>
	</channel-type>

	<channel-type id="litter-type">
		<item-type>String</item-type>
		<label>Litter Type</label>
		<state>
			<options>
				<option value="bentonite">Bentonite</option>
				<option value="mixed">Mixed</option>
			</options>
		</state>
	</channel-type>

	<channel-type id="safe-time">
		<item-type>String</item-type>
		<label>Safe Time (min)</label>
		<state>
			<options>
				<option value="1">1</option>
				<option value="3">3</option>
				<option value="5">5</option>
				<option value="7">7</option>
				<option value="10">10</option>
				<option value="15">15</option>
				<option value="30">30</option>
			</options>
		</state>
	</channel-type>

	<channel-type id="box-full-sensitivity">
		<item-type>String</item-type>
		<label>Box Full Sensitivity</label>
		<state>
			<options>
				<option value="1">Level 1</option>
				<option value="2">Level 2</option>
				<option value="3">Level 3</option>
				<option value="4">Level 4</option>
			</options>
		</state>
	</channel-type>

	<channel-type id="litter-weight">
		<item-type>Number</item-type>
		<label>Litter Weight</label>
		<state readOnly="true" pattern="%.1f kg"/>
	</channel-type>

	<channel-type id="litter-remaining-days">
		<item-type>Number</item-type>
		<label>Litter Remaining Days</label>
		<state readOnly="true" pattern="%.0f days"/>
	</channel-type>

	<channel-type id="temperature">
		<item-type>Number:Temperature</item-type>
		<label>Temperature</label>
		<category>Temperature</category>
		<state readOnly="true" pattern="%.1f %unit%"/>
	</channel-type>

	<channel-type id="humidity">
		<item-type>Number:Dimensionless</item-type>
		<label>Humidity</label>
		<category>Humidity</category>
		<state readOnly="true" pattern="%.0f %unit%"/>
	</channel-type>

	<channel-type id="percent">
		<item-type>Number:Dimensionless</item-type>
		<label>Level</label>
		<state readOnly="true" pattern="%.0f %unit%"/>
	</channel-type>

	<channel-type id="weight">
		<item-type>Number:Mass</item-type>
		<label>Weight</label>
		<state readOnly="true" pattern="%.0f %unit%"/>
	</channel-type>

	<channel-type id="total-clean-time">
		<item-type>Number</item-type>
		<label>Total Clean Count</label>
		<state readOnly="true" pattern="%d"/>
	</channel-type>

	<channel-type id="manual-clean-time">
		<item-type>Number</item-type>
		<label>Manual Clean Count</label>
		<state readOnly="true" pattern="%d"/>
	</channel-type>

	<channel-type id="deodorant-countdown">
		<item-type>Number</item-type>
		<label>Deodorant Countdown</label>
		<state readOnly="true" pattern="%.0f days"/>
	</channel-type>

	<channel-type id="wifi-rssi">
		<item-type>Number</item-type>
		<label>Wi-Fi RSSI</label>
		<state readOnly="true" pattern="%d"/>
	</channel-type>

	<channel-type id="wifi-ssid">
		<item-type>String</item-type>
		<label>Wi-Fi SSID</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="portions">
		<item-type>Number</item-type>
		<label>Portions</label>
		<description>Number of portions to dispense on Feed.</description>
		<state min="1" max="10" step="1" pattern="%d"/>
	</channel-type>

	<channel-type id="key-lock">
		<item-type>Switch</item-type>
		<label>Key Lock</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="online">
		<item-type>Switch</item-type>
		<label>Online</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="alarm">
		<item-type>String</item-type>
		<label>Alarm Status</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="error">
		<item-type>String</item-type>
		<label>Error Message</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="last-log">
		<item-type>String</item-type>
		<label>Last Event</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="garbage-status">
		<item-type>String</item-type>
		<label>Garbage Status</label>
		<state readOnly="true"/>
	</channel-type>

	<!-- Generic reusable types (label overridden per channel) -->
	<channel-type id="ro-string">
		<item-type>String</item-type>
		<label>Value</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="ro-number">
		<item-type>Number</item-type>
		<label>Value</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="ro-switch">
		<item-type>Switch</item-type>
		<label>State</label>
		<state readOnly="true"/>
	</channel-type>

	<channel-type id="switch-rw">
		<item-type>Switch</item-type>
		<label>Switch</label>
	</channel-type>

</thing:thing-descriptions>
